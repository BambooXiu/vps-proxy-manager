{
  "name": "zhiproxy",
  "version": "1.0.0",
  "description": "之竹Proxy - 一键管理 VPS 代理模式切换",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node scripts/test-config-generation.js",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "author": "Yue",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "ssh2": "^1.16.0",
    "qrcode": "^1.5.4"
  },
  "build": {
    "appId": "com.zhiproxy",
    "productName": "之竹Proxy",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "title": "之竹Proxy",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "directories": {
      "output": "dist"
    }
  }
}
